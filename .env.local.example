# LIFI API Key for cross-chain swaps
#NEXT_PUBLIC_LIFI_API_KEY=83f85c7b-97d2-4130-95b0-f72af1f0261e.b11f7330-ebb1-4684-af33-f28759ec6853

# Default node address for Swarm network
#NEXT_PUBLIC_DEFAULT_NODE_ADDRESS=0xb81784e65c84ca25b595ff4f0badb502673e343b

# StampsRegistryV2 on Gnosis (self-custody buy / top-up; optional override for forks)
#NEXT_PUBLIC_STAMPS_REGISTRY_V2_ADDRESS=0xA1a108E50FdB1aE7848a78577a37f7Bb8F27232f

# LIFI contract address for executing swaps
#NEXT_PUBLIC_LIFI_CONTRACT_ADDRESS=0x2dfaDAB8266483beD9Fd9A292Ce56596a2D1378D

# BZZ token address on Gnosis chain
#NEXT_PUBLIC_GNOSIS_BZZ_ADDRESS=0xdBF3Ea6F5beE45c02255B2c26a16F300502F68da

# Postage stamps contract address on Gnosis
#NEXT_PUBLIC_GNOSIS_STAMP_ADDRESS=0x45a1502382541Cd610CC9068e88727426b696293

# Bee API base URL (uploads, health). Default in code is https://beeport.xyz
#NEXT_PUBLIC_DEFAULT_BEE_API_URL=http://localhost:1633

# If your HTTPS gateway is HTTP/2 but hides Resource Timing protocol (no Timing-Allow-Origin),
# set true to ramp upload concurrency for any https:// Bee URL (not only the default host).
#NEXT_PUBLIC_ASSUME_HTTP2_UPLOAD=true

# Price oracle contract address on Gnosis
#NEXT_PUBLIC_GNOSIS_PRICE_ORACLE_ADDRESS=0x47EeF336e7fE5bED98499A4696bce8f28c1B0a8b

# Destination token address (USDC) for cross-chain swaps
#NEXT_PUBLIC_GNOSIS_DESTINATION_TOKEN=0xDDAfbb505ad214D7b80b1f830fcCc89B60fb7A83

# Optional private RPC per chain (prepended to fallbacks; used first). Key = chain id.
# NEXT_PUBLIC_RPC_1=https://eth-mainnet.g.alchemy.com/v2/your-key
# NEXT_PUBLIC_RPC_100=https://rpc.gnosischain.com
# NEXT_PUBLIC_RPC_8453=https://mainnet.base.org